{
  "name": "clashpulse-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "db:reset": "ts-node src/db/reset.ts",
    "jobs:poll-players": "ts-node src/jobs/poll-players.job.ts",
    "jobs:poll-clans": "ts-node src/jobs/poll-clans.job.ts",
    "test": "jest --passWithNoTests --forceExit"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/src/**/*.test.ts"],
    "setupFiles": ["<rootDir>/src/test-setup.ts"],
    "moduleNameMapper": {
      "^ioredis$": "<rootDir>/src/__mocks__/ioredis.ts",
      "^../db/pool$": "<rootDir>/src/__mocks__/pool.ts",
      "^../../db/pool$": "<rootDir>/src/__mocks__/pool.ts",
      "@shared/(.*)": "<rootDir>/../shared/$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    },
    "moduleNameMapper": {
      "@shared/(.*)": "<rootDir>/../shared/$1"
    }
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.12",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
